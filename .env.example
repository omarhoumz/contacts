# Copy to apps/web/.env.local and apps/mobile/.env.local (gitignored). Never commit real keys.

# --- Local Supabase (recommended for auth UX) ---
# From repo root: cd apps/backend && npx supabase start
# Keys: cd apps/backend && npx supabase status   (use API URL + Publishable key)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Hosted project (staging / cloud) ---
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<dashboard anon or publishable key>
# EXPO_PUBLIC_SUPABASE_URL=...
# EXPO_PUBLIC_SUPABASE_ANON_KEY=...
