{
  "name": "@widados/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "echo \"Supabase backend has no build step\"",
    "dev": "echo \"Run supabase start from apps/backend (see supabase/README.md)\"",
    "prepare:config": "node scripts/write-supabase-config.cjs",
    "db:start": "pnpm prepare:config && supabase start",
    "db:stop": "supabase stop",
    "db:status": "pnpm prepare:config && supabase status",
    "db:reset": "pnpm prepare:config && supabase db reset",
    "db:types": "supabase gen types typescript --local --schema public > supabase/database.types.ts",
    "lint": "eslint . --ext .ts,.tsx --no-error-on-unmatched-pattern --max-warnings 0 -c ../../.eslintrc.cjs",
    "typecheck": "node scripts/check-backend-config.mjs",
    "test": "node scripts/check-backend-config.mjs",
    "test:db": "pnpm prepare:config && supabase test db",
    "smoke:local-b8": "node scripts/smoke-local-b8.mjs"
  }
}
