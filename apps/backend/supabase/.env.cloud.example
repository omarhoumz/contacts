# Copy to `.env.cloud` in this directory (gitignored).
# Used by: pnpm env:supabase:cloud (repo root)
# Also used by: pnpm netlify:env:push → sets VITE_* on Netlify (D3).
# Values: Supabase dashboard → Project Settings → API (Project URL + publishable key).

SUPABASE_URL=<SUBSTITUTE_SUPABASE_URL>
SUPABASE_PUBLISHABLE_KEY=<SUBSTITUTE_SUPABASE_PUBLISHABLE_KEY>
