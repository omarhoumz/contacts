{
  "name": "widados",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "env:supabase:local": "node tooling/set-supabase-env.cjs local",
    "env:supabase:cloud": "node tooling/set-supabase-env.cjs cloud",
    "netlify": "netlify",
    "netlify:deploy": "netlify deploy --build --filter @widados/web",
    "netlify:deploy:prod": "netlify deploy --prod --build --filter @widados/web",
    "netlify:dev": "netlify dev",
    "netlify:link": "netlify link",
    "netlify:sites:create": "netlify sites:create",
    "netlify:open": "netlify open:site",
    "netlify:status": "netlify status",
    "netlify:env:list": "cd apps/web && netlify env:list --plain --context production",
    "netlify:env:push": "node tooling/netlify-env-push.cjs",
    "netlify:env:check": "node tooling/netlify-d3-check.cjs",
    "smoke:netlify-home": "node tooling/smoke-netlify-home.cjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "turbo": "^2.9.6"
  }
}
